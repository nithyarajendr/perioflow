# PerioFlow server-side environment variables.
#
# Local dev: copy this file to .env.local (git-ignored), then run `npm run dev:full`.
#   cp .env.example .env.local
#
# Production (Vercel): add ANTHROPIC_API_KEY in Project Settings → Environment Variables.
#
# The browser never reads these — only the /api/* serverless functions do.

ANTHROPIC_API_KEY=sk-ant-...
PORT=8787
